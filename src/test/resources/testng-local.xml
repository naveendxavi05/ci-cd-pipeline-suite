<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="CI-CD Pipeline Suite - Local" verbose="1" thread-count="1">

    <listeners>
        <listener class-name="com.naveen.listeners.ScreenshotListener"/>
    </listeners>

    <test name="Local Chrome Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.naveen.tests.LoginTest"/>
            <class name="com.naveen.tests.ProductTest"/>
            <class name="com.naveen.tests.CartTest"/>
            <class name="com.naveen.tests.CheckoutTest"/>
        </classes>
    </test>

</suite>